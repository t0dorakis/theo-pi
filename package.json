{
  "name": "theo-pi",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo of Pi packages, including pi-auto-skills and pi-caveman.",
  "author": "Theo",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t0dorakis/theo-pi.git"
  },
  "homepage": "https://github.com/t0dorakis/theo-pi#readme",
  "bugs": {
    "url": "https://github.com/t0dorakis/theo-pi/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "skills",
    "extensions",
    "autonomous-agents",
    "procedural-memory"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "node --check scripts/vm/pi-worker-gateway.ts scripts/vm/pi-worker-telegram-bot.ts scripts/vm/pi-worker-telegram-runner.ts scripts/vm/pi-worker-submit-job.ts scripts/vm/pi-worker-run-job.ts scripts/vm/pi-worker-acp-stdio.ts scripts/vm/pi-worker-acp-stdio-smoke-test.ts scripts/vm/lib/worker-runner.ts",
    "check:ts": "bunx tsc --noEmit",
    "test:vm": "bash scripts/vm/pi-worker-supervisor-smoke-test && bash scripts/vm/pi-worker-gateway-smoke-test",
    "test:vm:acpx": "bash scripts/vm/pi-worker-acpx-smoke-test",
    "test:conformance": "bun scripts/vm/pi-worker-conformance.ts",
    "test:conformance:core": "bun scripts/vm/pi-worker-conformance.ts --core-only",
    "test:acp-adapter": "bun scripts/vm/pi-worker-acp-stdio-smoke-test.ts",
    "worker:acp": "bash scripts/vm/pi-worker-acp"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "latest"
  },
  "pi": {
    "extensions": [
      "./packages/pi-auto-skills/extensions/auto-skills.ts",
      "./packages/pi-caveman/extensions/caveman.ts",
      "./packages/pi-task-loop/extensions/task-loop.ts"
    ]
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@sinclair/typebox": "^0.34.49",
    "acpx": "0.6.1",
    "grammy": "^1.42.0"
  }
}
