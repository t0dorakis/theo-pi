{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["bun-types"]
  },
  "include": ["scripts/**/*.ts"]
}
