#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SUPERVISOR="$SCRIPT_DIR/pi-worker-supervisor"
FAIL_INJECT="$SCRIPT_DIR/pi-worker-fail-inject"

SESSION="${1:-}"
[[ -n "$SESSION" ]] || { echo "usage: pi-worker-runtime-checklist <session>" >&2; exit 1; }

pass() { printf '[pass] %s\n' "$1"; }
fail() { printf '[fail] %s\n' "$1"; exit 1; }

status_json() {
  "$SUPERVISOR" status "$SESSION" --json
}

STATUS="$(status_json)"
WORKSPACE="$(echo "$STATUS" | jq -r '.workspacePath // empty')"
[[ -n "$WORKSPACE" ]] || fail 'status returns workspace path'
pass 'status returns workspace path'

echo "$STATUS" | jq -e '.sessionName == '"\"$SESSION\""'' >/dev/null || fail 'status returns session name'
pass 'status returns session name'

[[ -f "${PI_WORKER_STATE_DIR:-$HOME/.pi-worker}/state.json" ]] || fail 'state.json exists'
[[ -f "${PI_WORKER_STATE_DIR:-$HOME/.pi-worker}/heartbeat.json" ]] || fail 'heartbeat.json exists'
[[ -f "${PI_WORKER_STATE_DIR:-$HOME/.pi-worker}/health.json" ]] || fail 'health.json exists'
[[ -f "${PI_WORKER_STATE_DIR:-$HOME/.pi-worker}/supervisor.log" ]] || fail 'supervisor.log exists'
pass 'state files exist'

START_RESTARTS="$(echo "$STATUS" | jq -r '.restartCount')"
"$FAIL_INJECT" kill "$SESSION" >/dev/null
RECOVERED=0
for _ in 1 2 3 4 5 6 7 8; do
  sleep 2
  STATUS="$(status_json)"
  CUR_RESTARTS="$(echo "$STATUS" | jq -r '.restartCount')"
  if echo "$STATUS" | jq -e '.daemonStatus == "running" and .ok == true' >/dev/null && [[ "$CUR_RESTARTS" -gt "$START_RESTARTS" ]]; then
    RECOVERED=1
    break
  fi
done
[[ "$RECOVERED" -eq 1 ]] || fail 'kill test recovers and increments restart count'
pass 'kill test recovers and increments restart count'

"$FAIL_INJECT" stale "$SESSION" 600 >/dev/null
STATUS="$(status_json)"
echo "$STATUS" | jq -e '.daemonStatus == "stale" or ((.notes | index("heartbeat stale")) != null)' >/dev/null || fail 'stale heartbeat reflected in health'
pass 'stale heartbeat reflected in health'

"$SUPERVISOR" restart "$SESSION" >/dev/null
sleep 2
STATUS="$(status_json)"
echo "$STATUS" | jq -e '.daemonStatus == "running" and .ok == true' >/dev/null || fail 'restart clears stale state'
pass 'restart clears stale state'

BROKEN_PATH="$($FAIL_INJECT break-workspace "$SESSION")"
sleep 2
STATUS="$(status_json)"
echo "$STATUS" | jq -e '.daemonStatus == "failed" and ((.notes | index("workspace path missing")) != null)' >/dev/null || fail 'broken workspace reflected in health'
pass 'broken workspace reflected in health'

"$FAIL_INJECT" restore-workspace "$SESSION" >/dev/null
"$SUPERVISOR" restart "$SESSION" >/dev/null
sleep 2
STATUS="$(status_json)"
echo "$STATUS" | jq -e '.daemonStatus == "running" and .ok == true' >/dev/null || fail 'restore workspace + restart recovers'
pass 'restore workspace + restart recovers'

CHECKPOINT_PATH="$($SUPERVISOR checkpoint runtime-checklist)"
[[ -f "$CHECKPOINT_PATH" ]] || fail 'checkpoint created'
pass 'checkpoint created'

"$SUPERVISOR" verify >/dev/null || fail 'supervisor verify passes'
pass 'supervisor verify passes'

pass 'runtime checklist completed'
